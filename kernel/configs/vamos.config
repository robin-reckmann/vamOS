# GRAPHICS
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_DRM=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_MIPI_DSI=y
CONFIG_DRM_MSM=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_PANEL_DWO_DO0200FAT07=y
CONFIG_DRM_PANEL_SAMSUNG_EA8074=y
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_OCMEM=y

# OVERLAYFS
CONFIG_OVERLAY_FS=y

# UFS
CONFIG_PHY_QCOM_QMP=y
CONFIG_PHY_QCOM_QMP_UFS=y
CONFIG_SCSI_UFS_QCOM=y

# USB
CONFIG_PHY_QCOM_QMP_COMBO=y
CONFIG_PHY_QCOM_QMP_USB=y
CONFIG_PHY_QCOM_QUSB2=y
CONFIG_TYPEC=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_WWAN=y
CONFIG_USB_SERIAL_OPTION=y

# Networking
CONFIG_IPV6=y

# Bluetooth
CONFIG_BT=y
CONFIG_BT_LE=y
CONFIG_BT_QCA=y
CONFIG_POWER_SEQUENCING=y
CONFIG_SERIAL_DEV_BUS=y
CONFIG_SERIAL_DEV_CTRL_TTYPORT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_SERDEV=y
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_HCIUART_QCA=y

# WiFi
CONFIG_RFKILL=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_ATH10K=y
CONFIG_ATH10K_SNOC=y

# Firmware built into the kernel image (loaded before rootfs is mounted)
CONFIG_EXTRA_FIRMWARE="regulatory.db regulatory.db.p7s"

# Remoteproc / Modem
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_Q6V5_ADSP=y
CONFIG_QCOM_Q6V5_MSS=y
CONFIG_QCOM_Q6V5_PAS=y
CONFIG_QCOM_SYSMON=y
CONFIG_RPMSG_QCOM_GLINK_SMEM=y
CONFIG_QRTR=y
CONFIG_QRTR_SMD=y
CONFIG_QCOM_PDR_HELPERS=y
CONFIG_RPMSG_CHAR=y
CONFIG_RESET_QCOM_PDC=y

# PPP (for USB LTE modem data connection)
CONFIG_PPP=y
CONFIG_PPP_ASYNC=y
CONFIG_PPP_DEFLATE=y
CONFIG_PPP_BSDCOMP=y
CONFIG_PPP_MPPE=y

# I2C
CONFIG_I2C_QCOM_GENI=y

# SPI
CONFIG_SPI_QCOM_GENI=y
CONFIG_SPI_SPIDEV=y
CONFIG_QCOM_GPI_DMA=y

# Power monitoring (INA231)
CONFIG_SENSORS_INA2XX=y

# Touchscreen
CONFIG_TOUCHSCREEN_EDT_FT5X06=y
CONFIG_TOUCHSCREEN_S6SY761=y

# Sound
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_PCM=y
CONFIG_SND_DMAENGINE_PCM=y
CONFIG_SND_SOC=y
CONFIG_QCOM_APR=y
CONFIG_SOUNDWIRE=y
CONFIG_SND_SOC_QCOM=y
CONFIG_SND_SOC_QDSP6=y
CONFIG_SND_SOC_SDM845=y
CONFIG_SND_SOC_GENERIC_CODEC=y

# GPIO
# TODO: migrate gpio.sh, lte.sh, and power_drop_monitor.py to chardev (libgpiod)
# and remove GPIO_SYSFS (deprecated)
CONFIG_EXPERT=y
CONFIG_GPIO_SYSFS=y

# EROFS
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP=y
CONFIG_EROFS_FS_ZIP_LZ4=y

# Misc
CONFIG_LOCALVERSION_AUTO=n
